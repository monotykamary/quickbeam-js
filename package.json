{
  "name": "quickbeam-js",
  "version": "0.1.0",
  "description": "OTP patterns in JavaScript, on the BEAM — Supervisors, GenServers, Registries, Pools, Tasks, and Applications built on QuickBEAM primitives.",
  "author": "monotykamary",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/quickbeam-js.git"
  },
  "bugs": {
    "url": "https://github.com/monotykamary/quickbeam-js/issues"
  },
  "homepage": "https://github.com/monotykamary/quickbeam-js#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "keywords": [
    "otp",
    "beam",
    "quickbeam",
    "supervisor",
    "genserver",
    "erlang",
    "elixir",
    "actor-model"
  ]
}
